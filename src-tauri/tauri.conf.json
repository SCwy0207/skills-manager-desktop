{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skills Manager",
  "version": "1.0.1",
  "identifier": "com.skillsmanager.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Skills Manager",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src ipc: http://ipc.localhost",
      "capabilities": ["main"]
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Victor Kuo",
    "copyright": "Copyright © 2026 Victor Kuo",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "category": "DeveloperTool",
    "targets": "all",
    "windows": {
      "allowDowngrades": false,
      "webviewInstallMode": {
        "type": "offlineInstaller",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "SimpChinese", "TradChinese"],
        "displayLanguageSelector": false,
        "compression": "lzma",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "installer-assets/nsis-header.bmp",
        "uninstallerHeaderImage": "installer-assets/nsis-header.bmp",
        "sidebarImage": "installer-assets/nsis-sidebar.bmp",
        "startMenuFolder": "Skills Manager"
      },
      "wix": {
        "upgradeCode": "ef5db993-a6fc-52a9-97f5-e127aa68d332",
        "language": "en-US",
        "bannerPath": "installer-assets/wix-banner.bmp",
        "dialogImagePath": "installer-assets/wix-dialog.bmp"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Local-first manager for AI coding sessions and Agent Skills",
    "longDescription": "Search local Codex, Claude Code, and Cursor sessions and manage Agent Skills across all three without telemetry."
  }
}
